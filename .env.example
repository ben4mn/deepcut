# Postgres connection string used by Prisma and the app/worker processes.
# DATABASE_URL="postgres://deepcut:deepcut@localhost:5433/deepcut"

# next-auth (v5) secret used to sign session tokens/cookies. Generate with:
#   openssl rand -base64 32
# AUTH_SECRET=

# Base URL next-auth uses to build callback URLs, e.g. http://localhost:3000
# AUTH_URL=

# Spotify OAuth app credentials (developer.spotify.com/dashboard).
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# 32-byte hex key used to encrypt Spotify access/refresh tokens at rest (AES-256-GCM).
# Generate with:
#   openssl rand -hex 32
# TOKEN_ENCRYPTION_KEY=

# How often (in minutes) the worker polls each connected account's recently-played tracks.
# POLL_INTERVAL_MINUTES=30
